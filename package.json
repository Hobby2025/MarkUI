{
  "name": "markui",
  "displayName": "MarkUI",
  "description": "React 기반 컴포넌트형 Markdown 미리보기 VS Code 확장 프로그램입니다.",
  "version": "1.0.2",
  "publisher": "stjoo0925",
  "license": "MIT",
  "icon": "resources/crayon_star_marketplace.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Hobby2025/MarkUI.git"
  },
  "bugs": {
    "url": "https://github.com/Hobby2025/MarkUI/issues"
  },
  "homepage": "https://github.com/Hobby2025/MarkUI#readme",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "keywords": [
    "markdown",
    "preview",
    "webview",
    "document",
    "carbon"
  ],
  "galleryBanner": {
    "color": "#0f62fe",
    "theme": "dark"
  },
  "activationEvents": [
    "onCommand:markui.openPreview",
    "onLanguage:markdown"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "markui.openPreview",
        "title": "Markdown 미리보기 열기",
        "category": "MarkUI",
        "icon": {
          "light": "resources/crayon_star_ide.svg",
          "dark": "resources/crayon_star_ide.svg"
        }
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "markui.openPreview",
          "when": "resourceLangId == markdown",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "test": "tsx tests/markdownRenderer.test.ts && tsx tests/documentPage.test.ts && tsx tests/previewPanelConnection.test.ts",
    "check": "npm test && tsc --noEmit && tsc -p tsconfig.webview.json --noEmit && vite build",
    "build": "tsc -p . && tsc -p tsconfig.webview.json --noEmit && vite build",
    "watch": "tsc -w -p .",
    "package": "npm run build"
  },
  "dependencies": {
    "@carbon/icons-react": "^11.80.0",
    "@carbon/react": "^1.107.0",
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.1.0",
    "markdown-it-footnote": "^4.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^20.19.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/vscode": "^1.90.0",
    "@vitejs/plugin-react": "^4.6.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
